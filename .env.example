MONGODB_URI="mongodb+srv://gagan:REPLACE_PASSWORD@cluster0.rjal6j8.mongodb.net/fixmycampus?retryWrites=true&w=majority"
JWT_SECRET=your_jwt_secret_key_change_this_in_production
NODE_ENV=development
VITE_API_BASE=http://localhost:5000
PORT=5000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Notes:
# - Replace REPLACE_PASSWORD with your Atlas user password (URL-encode special characters if needed).
# - Keep this file private and do not commit real secrets.
